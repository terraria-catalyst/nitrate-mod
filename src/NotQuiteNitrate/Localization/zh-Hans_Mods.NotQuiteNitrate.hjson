Configs: {
	Config: {
		DisplayName: NQN配置

		BetterLiquidSlopes: {
			Label: 更好的液体斜坡
			Tooltip:
				'''
				在图格上再次渲染液体斜坡，以修复臭名昭著的
                漏洞——当站在液体下方的斜坡物块上时，实体无法正确着色。
				这也会第二次渲染该图格，意味着该图格将受到液体着色器的影响。
				我认为这会产生一种不错的效果，但这样做会带来一些细微的问题：
				- 紧邻液体的物块上不会显示挖掘进度。
				- 某些情况下，斜坡物块的光照会有轻微问题。

				由于不兼容，启用Nitrate后不会生效。
				'''
		}
	}
}
